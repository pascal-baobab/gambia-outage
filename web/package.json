{
  "name": "gambia-outage-web",
  "private": true,
  "version": "0.126.0",
  "type": "module",
  "description": "Gambia Outage — Report the Dark. PWA frontend (React + Vite + TS + Tailwind).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:avatars": "tsx scripts/gen-avatars.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.16",
    "leaflet": "1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@dicebear/collection": "9",
    "@dicebear/core": "9",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.8.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.4",
    "workbox-cacheable-response": "7.3.0",
    "workbox-core": "7.3.0",
    "workbox-expiration": "7.3.0",
    "workbox-precaching": "7.3.0",
    "workbox-routing": "7.3.0",
    "workbox-strategies": "7.3.0"
  }
