# .env.example — Gambia Outage. On the server this lives at /root/.env (chmod 600).
# Copy to .env locally / /root/.env on the box and fill real values. NEVER commit .env.

# ── Core config (prompt-claude-code.md §4.8) ──────────────────────────────
TZ=Africa/Banjul
DAILY_SALT=change-me-rotated-daily-by-cron     # rotated daily @00:05 Banjul (stored in read_models)
CONFIRM_THRESHOLD=8                            # distinct rl_key OUT reports → "confirmed"
RL_OUT_WINDOW_MIN=10                           # DEPRECATED 2026-06-10: no longer enforced (repeat OUT now allowed to re-affirm flapping outages; trust is distinct-rl_key capped)
RL_HOURLY=30                                   # ≤30 reports per rl_key / hour
SNAP_RADIUS_KM=3                               # GPS → nearest settlement centroid
AUTOCLOSE_IDLE_HOURS=6                         # close event after idle
MAX_EVENT_HOURS=24                             # hard cap on open event age
NOTE_MAX=140                                   # note length cap
POST_HOURLY=10                                 # community: max Stories posts per account / hour
COMMENT_HOURLY=30                              # community: max comments per account / hour
SUB_MAX=20                                     # ≤ push subscriptions per ZONE (FIFO-evicts oldest)
BACK_CLOSE_FLOOR=3                              # distinct 'back' reporters needed to close an event (launch: set 2 in prod)
NAME_INACTIVE_DAYS=7                            # auto-release a claimed name after N days of total account inactivity (0=disables the GC)

# ── Geo-gate: outage reports only from inside The Gambia (CF-IPCountry via the tunnel) ──
GEO_GATE=true                                  # false disables; fails OPEN when country is unknown (dev/local)
GEO_ALLOW=GM                                    # comma-separated ISO-3166-1 allowlist of countries that may report

# ── Sybil hardening (ip_key — salted-hashed IP, daily rotation, reports-only) ──
RL_IP_HOURLY=90                                 # max reports/hour from ONE IP no matter how many UAs it rotates
IP_DEVICE_MULT=3                                # distinct-reporter counts capped at distinctIPs × this (household/CGNAT allowance)
BACK_CLOSE_IP_FLOOR=2                           # closing an event via 'back' needs ≥ this many distinct IPs

# ── Pocketbase admin (superuser; used by seed + provisioning) ─────────────
PB_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=admin@gambiaoutage.com
PB_ADMIN_PASSWORD=                             # strong; set on the server only

# ── Web Push / VAPID (Phase 3 — generate a keypair; keep PRIVATE secret) ──
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:ops@gambiaoutage.com
PUSH_POLL_MS=10000                             # push-worker poll interval
PUSH_MAX_ATTEMPTS=5                            # retries before dropping a transiently-failing queue row

# ── Telegram ingest bot (owner-curated "From Facebook" cards) — sidecar idles until both are set ──
TELEGRAM_BOT_TOKEN=                            # from @BotFather; keep secret (server only)
TELEGRAM_ADMIN_IDS=                            # comma-separated numeric Telegram user IDs allowed to publish (owner only)
TELEGRAM_POLL_TIMEOUT=30                       # long-poll seconds

# ── Turnstile (anti-bot on report POST + push subscribe; create a widget in the CF dashboard) ──
# When TURNSTILE_SECRET is unset, the backend skips the challenge (dev/local stays usable).
# Test keys (always pass): SITE=1x00000000000000000000AA  SECRET=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=                            # public — served at /api/go/turnstile
TURNSTILE_SECRET=                              # secret — server-side siteverify only

# ── Backup: Litestream → Cloudflare R2 (S3-compatible) ────────────────────
R2_ENDPOINT=                                   # https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=                                     # the ACTIVE R2 bucket name
R2_ACCESS_KEY_ID=                              # R2 API token access key id
R2_SECRET_ACCESS_KEY=                          # R2 API token secret

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────
TUNNEL_NAME=gambia-outage                      # `cloudflared tunnel create $TUNNEL_NAME`
# Tunnel creds file: /root/.cloudflared/<tunnel-id>.json (chmod 600; created by `tunnel create`)

# ── Deploy facts (NON-secret; for reference by deploy/ scripts) ───────────
# SERVER_HOST=                                  # your server's IP or hostname
# DEPLOY_USER=deploy                            # non-root sudo user (created by 00-bootstrap.sh)
# APP_DIR=/opt/gambia-outage
